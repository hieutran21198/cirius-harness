# Devenv
.devenv*
devenv.local.nix
devenv.local.yaml

# node modules
node_modules

# direnv
.direnv

# pre-commit
.pre-commit-config.yaml

# harness runtime state (SQLite DBs + WAL/SHM sidecars) + built binary
/.cirius-harness/state/
/.cirius-harness/bin/

# AI assets
.agents
.opencode
.claude
.codegraph
.gemini
.mcp.json
skills-lock.json

# Pi: runtime state AND the built extension are generated; only the README is tracked.
# The extension SOURCE lives in apps/pi-harness-extension/ and is compiled into
# .pi/extensions/ via `devenv tasks run pi-extension:build` (ADR-0008).
.pi/*
!.pi/README.md

# nx
.nx/cache
.nx/workspace-data

# Editor assets
.vscode
.idea

# Deployment: never commit filled-in env files; keep the *.example templates
deploy/**/*.env
!deploy/**/*.env.example
