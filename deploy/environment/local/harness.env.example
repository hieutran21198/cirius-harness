# local environment — copy to `harness.env` (gitignored) and fill in.
# Never commit real credentials.

# ─── Provider auth (LIVE) ───────────────────────────────────────────────────
# Read by the coding client (Pi), NOT by the harness. Uncomment the providers
# you use. Alternatively authenticate inside the client (Pi: `/login`).
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GEMINI_API_KEY=
# DEEPSEEK_API_KEY=
# MINIMAX_API_KEY=
# OPENROUTER_API_KEY=

# ─── Harness config (RESERVED / forward-looking) ────────────────────────────
# Not consumed yet — the `harness serve` DB path is currently a CLI argument.
# Listed to document the intended contract; setting these has no effect today.
# HARNESS_DB_PATH=.cirius-harness/state/harness.sqlite
# HARNESS_LOG_LEVEL=debug
